# Autenticação e Token do OpenAI (usado pela função ai-chat)
supabase secrets set OPENAI_API_KEY="seu_token_da_openai_aqui"

# Configuração da Evolution API (usada pelo whatsapp-webhook para responder as mensagens)
supabase secrets set EVOLUTION_API_URL="https://sua-evolution-api.com"
supabase secrets set EVOLUTION_API_TOKEN="seu_token_global_da_evolution_aqui"

# Configuração de Segurança Interna
# Chave mestra (Service Role) do Supabase para que as funções alterem dados burlando o RLS
supabase secrets set SUPABASE_SERVICE_ROLE_KEY="sua_service_role_key_aqui"

# Integração com as APIs do Google (OAuth2 / Google Calendar Sync)
supabase secrets set GOOGLE_CLIENT_ID="seu_google_client_id_aqui"
supabase secrets set GOOGLE_CLIENT_SECRET="seu_google_client_secret_aqui"
supabase secrets set GOOGLE_REDIRECT_URI="https://id-projeto.supabase.co/functions/v1/google-auth"